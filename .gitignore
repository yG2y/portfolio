# =========================
# Global ignores (repo root)
# =========================

# Environment / secrets
.env
.env.local
.env.*
!.env.example
!.env.*.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS / editor noise
.DS_Store
Thumbs.db

# Python cache (for future services/scripts)
__pycache__/
*.pyc

# Temporary files
*.tmp
*.temp

# Optional local IDE state
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
